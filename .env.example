# ─────────────────────────────────────────────────────────────
# Remasia / ريماسيا — environment variables
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# Postgres. Used by Prisma CLI (migrate/db push/seed) and the runtime PrismaPg adapter.
# Local dev: `docker compose up -d` starts Postgres on host port 5433 (see docker-compose.yml).
DATABASE_URL="postgresql://remasia:remasia@localhost:5433/remasia?schema=public"
# Production (Neon / Supabase) looks like:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/remasia?sslmode=require"

# Secret used to sign the single-admin Studio session cookie (lib/auth.ts).
# Generate with:  openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"

# UploadThing (bouquet & garden image uploads). From uploadthing.com dashboard.
UPLOADTHING_TOKEN=""
